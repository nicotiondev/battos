# --- BattOS ---
BATTOS_ENV=development
BATTOS_PUBLIC_URL=http://localhost:3000
BATTOS_API_URL=http://localhost:8000
BATTOS_SECRET_KEY=change-me-please
BATTOS_API_TOKEN=change-me-to-a-long-random-token

# --- Postgres ---
POSTGRES_DB=battos
POSTGRES_USER=battos
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://battos:change-me@battos-db:5432/battos?sslmode=disable

# --- Providers (solo presencia se valida en v0.1, no se llaman) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# --- Integraciones (todas opcionales en v0.1) ---
N8N_API_URL=
N8N_API_KEY=
NOTION_API_KEY=
NOTION_WORKSPACE_ID=
GITHUB_TOKEN=
TELEGRAM_BOT_TOKEN=
OBSIDIAN_VAULT_PATH=

# --- Guardrails de seguridad ---
ALLOW_CLI_EXECUTION=false
ALLOW_DOCKER_INSPECTION=true
ALLOW_DOCKER_MUTATION=false
REQUIRE_APPROVAL_FOR_HIGH_RISK=true

# --- Worker de runs ---
# Por defecto el servicio worker corre en dry_run. Para DockerSandbox usa:
# docker compose -f infra/docker-compose.yml -f infra/docker-compose.worker-docker.yml --env-file infra/.env --profile worker up -d battos-worker
BATTOS_EXECUTION_SANDBOX_MODE=dry_run
BATTOS_EXECUTION_DOCKER_IMAGE=battos-runtime-agents:dev
BATTOS_EXECUTION_WORKSPACES_DIR=/app/data/runs/workspaces
BATTOS_EXECUTION_POLL_INTERVAL_S=2

# Versiones npm opcionales para construir infra/Dockerfile.runtime-agents.
BATTOS_CODEX_NPM_VERSION=latest
BATTOS_CLAUDE_NPM_VERSION=latest
